# ── Server ────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── MongoDB Atlas ──────────────────────────────────────
# Get from: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/vedaai?retryWrites=true&w=majority

# ── Google Gemini AI (free tier) ───────────────────────
# Get free key: https://aistudio.google.com/app/apikey
# Leave empty to use demo/fallback mode
GEMINI_API_KEY=

# ── Demo Mode ──────────────────────────────────────────
# Set true to force fallback paper even if key exists
DEMO_MODE=false

# ── Redis/Upstash (Phase 5) ────────────────────────────
REDIS_URL=rediss://default:token@host.upstash.io:6379