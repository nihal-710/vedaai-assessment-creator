# -------------------------------------------
# SERVER
# -------------------------------------------
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# -------------------------------------------
# MONGODB ATLAS (free tier)
# Get from: https://cloud.mongodb.com
# Format: mongodb+srv://user:pass@cluster.mongodb.net/vedaai
# -------------------------------------------
MONGODB_URI=mongodb+srv://vedaai:YOURPASSWORD@cluster0.xxxxx.mongodb.net/vedaai?retryWrites=true&w=majority

# -------------------------------------------
# UPSTASH REDIS (free tier, no Docker needed)
# Get from: https://console.upstash.com
# Format: rediss://default:TOKEN@host.upstash.io:6379
# -------------------------------------------
REDIS_URL=rediss://default:YOURTOKEN@xxxxx.upstash.io:6379

# -------------------------------------------
# AI - Google Gemini (free tier)
# Get from: https://aistudio.google.com/app/apikey
# No credit card required
# -------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# -------------------------------------------
# DEMO MODE
# Set to true if you have no API key yet
# App will use mock data instead of real AI
# -------------------------------------------
DEMO_MODE=false
